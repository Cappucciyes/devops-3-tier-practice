# ========================================
# Backend 환경변수 (로컬 참고용 placeholder)
# 실제 EC2 인스턴스의 .env는 Launch Template userdata가
# RDS 엔드포인트를 주입해 /home/ubuntu/backend/.env 로 생성합니다.
# (이 파일은 CodeDeploy 번들에서 제외되어 인스턴스로 배포되지 않음)
# ========================================

# 서버 포트
PORT=8080

# RDS 연결 정보
DB_HOST=your-rds-endpoint.ap-northeast-2.rds.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=your-password-here
DB_NAME=guestbook
